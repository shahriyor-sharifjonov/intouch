mixin product()
    .popular__slide.product 
        .popular__slide-img 
            img(src="@img/slide-1.png", alt="" draggable="false")
        p.popular__slide-title Сенсорная панель intouch INT 55
        button(type="button" data-target="product").open-popup.popular__slide-btn Подробнее
        
